databaseChangeLog:
  - changeSet:
      id: 002-create-rule-steps-table
      author: dev
      changes:
        - createTable:
            tableName: rule_steps
            columns:
              - column:
                  name: id
                  type: bigint auto_increment
                  constraints:
                    primaryKey: true
                    nullable: false
              - column:
                  name: rule_id
                  type: varchar(255)
                  constraints:
                    foreignKeyName: fk_rule_steps_rule
              - column:
                  name: step_order
                  type: int
              - column:
                  name: condition
                  type: text
